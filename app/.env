# Jarvis Agent Framework - Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit the .env file to git - it's in .gitignore

# ===== DATABASE =====
# PostgreSQL Example:
DATABASE_URL=postgresql://user:password@localhost:5432/jarvis_db
# SQLite Example (development only):
# DATABASE_URL=sqlite:///./jarvis.db

# ===== ENVIRONMENT =====
# Use 'development' for local testing with verbose logging
# Use 'production' for deployment with minimal logging
ENV=development

# ===== LOGGING =====
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
LOG_FILE=logs/jarvis.log

# ===== OLLAMA/LLM CONFIGURATION =====
# Ollama endpoint (if using local Ollama)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=tinyllama:latest
OLLAMA_TEMPERATURE=0.7
OLLAMA_MAX_RETRIES=3
OLLAMA_TIMEOUT=30

# OpenAI Configuration (if using OpenAI instead)
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_MODEL=gpt-4

# ===== VECTOR DATABASE (QDRANT) =====
QDRANT_HOST=127.0.0.1
QDRANT_PORT=6333
QDRANT_COLLECTION=agent_memory
QDRANT_API_KEY=  # Leave empty for local, add key for cloud

# ===== EMBEDDINGS =====
EMBEDDING_MODEL=BAAI/bge-small-en
HUGGINGFACE_TOKEN=  # Optional: for private models

# ===== API CONFIGURATION =====
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true  # Auto-reload on file changes (dev only)

# ===== MEMORY SETTINGS =====
MEMORY_TOP_K=3
MEMORY_SIMILARITY_THRESHOLD=0.7

# ===== AGENT MODELS (If using multiple models) =====
PLANNER_MODEL=tinyllama:latest
EXECUTOR_MODEL=tinyllama:latest
REVIEWER_MODEL=tinyllama:latest

# ===== SECURITY =====
# Add CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# API Key for authentication (optional)
# API_KEY=your-secret-api-key-here

# ===== TIMEOUT SETTINGS =====
REQUEST_TIMEOUT=30
TASK_TIMEOUT=300
MEMORY_TIMEOUT=10

# ===== DATABASE POOL SETTINGS =====
# For PostgreSQL only
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=3600  # Recycle connections every hour

# ===== DEBUGGING =====
# Enable detailed debugging (set to true only in development)
DEBUG=false
# Enable API request/response logging
LOG_REQUESTS=false

